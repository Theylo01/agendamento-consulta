# Node
# Fuso horário utilizado pela aplicação e pelos processos Node.js
TZ=UTC
# Porta em que o servidor AdonisJS ficará disponível dentro do container
PORT=3333
# Endereço de rede onde a aplicação escuta conexões
# 0.0.0.0 permite acesso externo ao container
HOST=0.0.0.0
NODE_ENV=production

# App
# Nível de detalhamento dos logs exibidos pela aplicação
# info = informações gerais, erros e avisos importantes
LOG_LEVEL=info
# Chave secreta utilizada pelo AdonisJS para criptografia,
# cookies, sessões e outras operações de segurança
APP_KEY=zTqqLi8WrufWueWsH1Y8pQAWTxswT2ha
APP_URL=http://localhost:3333

# Session
# Define onde as sessões serão armazenadas
# cookie = armazenadas diretamente nos cookies do navegador
SESSION_DRIVER=cookie
# Nome do serviço PostgreSQL definido no docker-compose.yml
# O Docker resolve automaticamente esse nome para o IP do container
DB_HOST=postgres
# Porta padrão do PostgreSQL
DB_PORT=5432
# Usuário do banco de dados
DB_USER=postgres
# Senha do usuário do banco
DB_PASSWORD=senha123
# Nome do banco de dados utilizado pela aplicação
DB_DATABASE=consultas_db